{
    "geode": "5.6.1",
    "gd": {
        "win": "2.2081",
        "mac": "2.2081",
        "android": "2.2081",
        "ios": "2.2081"
    },
    "version": "1.1.1",
    "id": "malikhw47.reversed-inputs",
    "name": "Reversed Inputs",
    "developer": "MalikHw47",
    "description": "Swaps your inputs, hold to do nothing, tap to jump",
    "tags": ["gameplay", "joke"],
    "links": {
        "source": "https://github.com/MalikHw/FuckedInputs",
        "community": "https://discord.gg/G9bZ92eg2n"
    },
    "settings": {
        "reversed-inputs-enabled": {
            "name": "Toggle",
            "description": "toggle functionality",
            "type": "bool",
            "default": false
        },
        "allow-in-practice": {
            "name": "Allow in Practice Mode",
            "description": "Whether reversed inputs applies in practice mode",
            "type": "bool",
            "default": false
        },
        "affect-player1": {
            "name": "Affect Player 1",
            "description": "Apply reversed inputs to Player 1",
            "type": "bool",
            "default": true
        },
        "affect-player2": {
            "name": "Affect Player 2",
            "description": "Apply reversed inputs to Player 2 in dual mode",
            "type": "bool",
            "default": true
        },
        "toggle-keybind": {
            "name": "Toggle keybind",
            "description": "keybind setting",
            "type": "keybind",
            "default": "F4",
            "category": "gameplay"
        }
    },
    "dependencies": {
        "eclipse.eclipse-menu": {
            "version": ">=v1.9.0",
            "required": false
        }
    }
}
